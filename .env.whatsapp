# ===================================
# WhatsApp 通知集成配置
# ===================================
# 
# WhatsApp 通知支持以下两种方式：
#
# 【方式一】Official WhatsApp Business API（推荐，生产环境）
# 1. 注册 Meta Business Account: https://www.facebook.com/business/tools/meta-business-suite
# 2. 设置 WhatsApp Business Account
# 3. 获取 Phone Number ID、WABA ID 和 Access Token
#
# WHATSAPP_PHONE_NUMBER_ID=123456789123456
# WHATSAPP_BUSINESS_ACCOUNT_ID=123456789123456
# WHATSAPP_ACCESS_TOKEN=EAABsabc...
# WHATSAPP_RECIPIENT_PHONE=+254768148010  # 接收人号码（包含国家代码）
#
# 【方式二】Twilio WhatsApp Sandbox（快速测试）
# 1. 注册 Twilio 账户: https://www.twilio.com/try-twilio
# 2. 创建 WhatsApp Sandbox: https://console.twilio.com/us/account/messaging/try-it-out
# 3. 获取 Account SID、Auth Token 和 Sandbox 号码
#
# TWILIO_ACCOUNT_SID=ACxxx...
# TWILIO_AUTH_TOKEN=xxx...
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155552671  # Twilio 沙箱号码
# WHATSAPP_RECIPIENT_PHONE=+254768148010
#
# 【方式三】WhatsApp Cloud API via Vonage（替代方案）
# VONAGE_API_KEY=xxx
# VONAGE_API_SECRET=xxx
# VONAGE_WHATSAPP_NUMBER=+1234567890
# WHATSAPP_RECIPIENT_PHONE=+254768148010
#
# ===================================
# 配置说明
# ===================================
#
# WHATSAPP_PROVIDER: official / twilio / vonage（默认 official）
WHATSAPP_PROVIDER=twilio
#
# WHATSAPP_RECIPIENT_PHONE: 接收通知的 WhatsApp 号码（包含 + 和国家代码）
WHATSAPP_RECIPIENT_PHONE=+254768148010
#
# WHATSAPP_MESSAGE_MAX_LENGTH: 单条消息最大字符数（默认 4096）
WHATSAPP_MESSAGE_MAX_LENGTH=4096
#
# WHATSAPP_RETRY_MAX: 发送失败最大重试次数（默认 3）
WHATSAPP_RETRY_MAX=3
#
# WHATSAPP_TIMEOUT_SEC: 请求超时秒数（默认 30）
WHATSAPP_TIMEOUT_SEC=30
#
# WHATSAPP_ENABLED: 是否启用 WhatsApp 通知（默认 true）
WHATSAPP_ENABLED=true
#
# ===================================
# Twilio 沙箱设置步骤（快速测试）
# ===================================
# 
# 1. 登录 https://console.twilio.com/us/account/messaging/try-it-out
# 2. 点击 "Send a WhatsApp Message"
# 3. 将提供的沙箱���码保存为 TWILIO_WHATSAPP_NUMBER
# 4. 从手机发送消息: "join [sandbox-code]" 到沙箱号码来加入沙箱
# 5. 获取 Account SID 和 Auth Token: https://console.twilio.com/us/account/keys
#
# ===================================
# 消息格式
# ===================================
#
# WhatsApp 消息支持以下格式：
# - 纯文本：自动换行，支持 emoji
# - 结构化消息（API 方式）：支持 Bold、Italic、Strikethrough、Monospace
# 
# 股票分析报告会自动格式化为易读的 WhatsApp 消息
#
